{
  "name": "kraft-lotto-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test tests/e2e/admin.spec.js tests/e2e/smoke.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:docker": "./scripts/e2e-docker.sh",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "check:js": "node scripts/check-js-syntax.cjs",
    "build:bootstrap": "postcss node_modules/bootstrap/dist/css/bootstrap.css -o src/main/resources/static/css/bootstrap.min.css --no-map",
    "build:css": "npm run build:bootstrap && postcss \"src/main/frontend/css/*.css\" --dir src/main/resources/static/css --no-map"
  },
  "devDependencies": {
    "bootstrap": "5.3.3",
    "@axe-core/playwright": "^4.11.3",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^3.2.6",
    "chrome-launcher": "^1.2.1",
    "cssnano": "^8.0.1",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.3.0",
    "postcss": "^8.5.4",
    "postcss-cli": "^11.0.1",
    "vitest": "^3.2.6"
  }
}
