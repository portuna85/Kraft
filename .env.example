# Docker Compose environment template — copy to .env for local Docker dev.
# NOT read by Spring Boot directly. Spring Boot in containers receives these
# values as OS environment variables via the 'environment:' blocks in
# docker-compose.yml / docker-compose.local.yml.
#
# For running Spring Boot OUTSIDE Docker (direct local dev):
#   copy .env.local.example -> .env.local and set your values there.

# ── MariaDB container ─────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=kraft_lotto
MARIADB_USER=kraft_lotto
MARIADB_PASSWORD=

# ── Backend (Spring Boot) ─────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
# 로컬에서 OAuth 로그인을 테스트하려면 아래처럼 provider profile을 추가하고
# (사용할 provider만) client id/secret 쌍을 함께 채운다. 두 값 중 하나만 있으면
# 해당 provider registration이 활성화되지 않는다(docs/improvement.md §5.4 참고).
# SPRING_PROFILES_ACTIVE=local,community-google-oauth,community-naver-oauth
# KRAFT_COMMUNITY_GOOGLE_CLIENT_ID=
# KRAFT_COMMUNITY_GOOGLE_CLIENT_SECRET=
# KRAFT_COMMUNITY_NAVER_CLIENT_ID=
# KRAFT_COMMUNITY_NAVER_CLIENT_SECRET=
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
KRAFT_DB_USERNAME=kraft_lotto
KRAFT_DB_PASSWORD=
KRAFT_FLYWAY_ENABLED=true
KRAFT_JPA_DDL_AUTO=validate
KRAFT_LOG_PATH=/app/logs
KRAFT_OPS_TOKEN=
KRAFT_REVALIDATE_SECRET=
KRAFT_SAVED_MAX_PER_CLIENT=100
KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE=
KRAFT_EXTERNAL_LOTTO_AUTO_COLLECT_CRON=0 30 21 * * SAT
KRAFT_EXTERNAL_LOTTO_REFERER=https://www.dhlottery.co.kr/lt645/result
KRAFT_EXTERNAL_LOTTO_REQUESTED_WITH=XMLHttpRequest
KRAFT_SECURITY_TRUSTED_PROXY_CIDR=172.28.0.0/16
KRAFT_SECURITY_RATE_LIMIT_PER_MINUTE=120
KRAFT_SECURITY_RATE_LIMIT_MAX_KEYS=10000
# Log retention (days). Defaults: operation-log=30, admin-audit-log=90
KRAFT_RETENTION_OPERATION_LOG_DAYS=30
KRAFT_RETENTION_ADMIN_AUDIT_LOG_DAYS=90

# ── Revalidate ────────────────────────────────────────────────────────────────
# URL the Spring Boot backend calls to trigger Next.js ISR revalidation (points to the web container)
KRAFT_REVALIDATE_WEB_URL=http://web:3000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080
KRAFT_PUBLIC_BASE_URL=http://localhost
# Ops page host restriction — set to admin hostname (e.g. admin.example.com) to block /ops on public domain.
# Leave empty to allow access from any host (local dev default).
KRAFT_OPS_ALLOWED_HOST=
# 슬롯당 애드핏/애드센스 중 하나만 렌더 — "adfit" 또는 "adsense" (기본값 adfit)
NEXT_PUBLIC_AD_NETWORK=adfit
# Kakao Adfit 광고 단위 코드 (비어 있으면 광고 미표시)
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_FREQUENCY=

# ── Caddy (used by docker-compose.prod.yml) ───────────────────────────────────
KRAFT_DOMAIN=localhost
KRAFT_ADMIN_DOMAIN=admin.localhost

# ── Docker image refs ─────────────────────────────────────────────────────────
KRAFT_BACKEND_IMAGE_REF=demo-backend
KRAFT_BACKEND_IMAGE_TAG=latest
KRAFT_WEB_IMAGE_REF=demo-web
KRAFT_WEB_IMAGE_TAG=latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
ALERTMANAGER_DISCORD_WEBHOOK_URL=
# ALERTMANAGER_DISCORD_WEBHOOK_URL이 비어 있으면 render-alertmanager.sh가 실패한다.
# 로컬/스테이징에서 알림 없이 기동하려면 아래를 명시적으로 true로 설정한다(운영 배포에는 쓰지 않는다).
ALERTING_DISABLED=
