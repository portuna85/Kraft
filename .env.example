# ============================================================
# Kraft Lotto environment example
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# ============================================================

# Minimum sets:
# - Local minimum: SPRING_PROFILES_ACTIVE, KRAFT_DB_USER, KRAFT_DB_PASSWORD
# - Prod minimum:  SPRING_PROFILES_ACTIVE, KRAFT_DB_USER, KRAFT_DB_PASSWORD,
#                  DB address vars, KRAFT_API_CLIENT, KRAFT_PUBLIC_BASE_URL,
#                  KRAFT_SECURITY_OPS_REQUIRED_TOKEN
# See: docs/env-minimums.md

# --- Spring profile ---
SPRING_PROFILES_ACTIVE=local

# --- Docker Compose ports ---
KRAFT_APP_PORT=8080
KRAFT_DB_PORT=3306

# --- Database ---
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_HOST=mariadb
KRAFT_DB_USER=kraft
KRAFT_DB_PASSWORD=change-me
KRAFT_DB_ROOT_PASSWORD=change-me-root
KRAFT_DB_CONNECTIVITY_CHECK_ENABLED=true
KRAFT_DB_CONNECTIVITY_CHECK_TIMEOUT_MS=1500

# For local bootRun on host OS
KRAFT_DB_LOCAL_HOST=localhost
KRAFT_IN_CONTAINER=false

# --- Lotto API ---
# local default: real, prod default: smok
KRAFT_API_CLIENT=real
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do
KRAFT_API_CONNECT_TIMEOUT_MS=2000
KRAFT_API_READ_TIMEOUT_MS=3000
KRAFT_API_REQUEST_TIMEOUT_MS=10000
KRAFT_API_MAX_RETRIES=2
KRAFT_API_RETRY_BACKOFF_MS=200
KRAFT_API_MOCK_LATEST_ROUND=1224

# --- Ops security ---
# Required in production. Used by /ops/** and /admin/ops.
KRAFT_SECURITY_OPS_REQUIRED_TOKEN=change-me-ops-token

# --- History init ---
# Recommended false in prod if DB is already initialized
# KRAFT_HISTORY_INIT_ENABLED=false

# --- Scheduler / auto collect ---
KRAFT_COLLECT_AUTO_ENABLED=true
KRAFT_COLLECT_AUTO_ZONE=Asia/Seoul
KRAFT_COLLECT_AUTO_CRON_SATURDAY_22_30=0 30 22 ? * SAT
KRAFT_COLLECT_AUTO_CRON_SUNDAY_07_00=0 0 7 ? * SUN

# --- Public base URL (for dynamic /sitemap.xml and /robots.txt) ---
KRAFT_PUBLIC_BASE_URL=https://www.kraft.io.kr

# --- Recommend engine ---
KRAFT_RECOMMEND_MAX_ATTEMPTS=5000
KRAFT_RECOMMEND_INITIAL_PICK_MAX_ATTEMPTS=10000
KRAFT_RECOMMEND_FIXUP_MAX_ATTEMPTS=1000
KRAFT_RECOMMEND_RULE_BIRTHDAY_THRESHOLD=31
KRAFT_RECOMMEND_RULE_LONG_RUN_THRESHOLD=5
KRAFT_RECOMMEND_RULE_DECADE_THRESHOLD=5

# --- Advanced runtime options ---
KRAFT_COLLECT_MAX_PER_RUN=52
KRAFT_COLLECT_MAX_HISTORY_COLLECT=2000

# API circuit breaker
KRAFT_API_CIRCUIT_BREAKER_ENABLED=true
KRAFT_API_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
KRAFT_API_CIRCUIT_BREAKER_OPEN_DURATION_MS=30000
KRAFT_API_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=1

# API backfill pacing
KRAFT_API_BACKFILL_DELAY_MS=700

# Security headers / CSP override
# KRAFT_SECURITY_HEADERS_ENABLED=true
# KRAFT_SECURITY_CSP=default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# --- Tracing ---
KRAFT_TRACING_ENABLED=false
KRAFT_TRACING_SAMPLING_PROBABILITY=1.0
KRAFT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces

# --- Collect log retention ---
KRAFT_COLLECT_LOG_RETENTION_ENABLED=true
KRAFT_COLLECT_LOG_RETENTION_DAYS=90
KRAFT_COLLECT_LOG_RETENTION_CRON=0 30 3 * * *

# --- Logging ---
KRAFT_LOG_PATH=./logs

# --- Container healthcheck ---
KRAFT_HEALTHCHECK_URL=http://localhost:8080/actuator/health/readiness
KRAFT_HEALTHCHECK_TIMEOUT_SECONDS=3
