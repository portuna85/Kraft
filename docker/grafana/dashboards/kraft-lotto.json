{
  "title": "kraft-lotto",
  "uid": "kraft-lotto",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "서킷브레이커 상태",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "kraft_api_circuit_breaker_state",
          "legendFormat": "{{client}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "HALF-OPEN", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "OPEN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "서킷브레이커 전이",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "increase(kraft_api_circuit_breaker_transitions_total[5m])",
          "legendFormat": "{{client}} {{from}}→{{to}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "수집 결과 (5분)",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "increase(kraft_collect_outcome_total[5m])",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "추천 생성 지연 (p95, ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(kraft_recommend_generation_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(kraft_recommend_generation_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "title": "추천 실패 (사유별)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "increase(kraft_recommend_generation_failure_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "fetch 지연 (p95, ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(kraft_collect_fetch_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Rate Limit 차단 비율",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(kraft_ratelimit_blocked_total[5m])",
          "legendFormat": "blocked/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "추천 요청 세트 수 (평균, 5분)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(kraft_recommend_request_count_sum[5m]) / rate(kraft_recommend_request_count_count[5m])",
          "legendFormat": "avg requested sets"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(kraft_recommend_request_count_count[5m])",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "폴백 사용 현황 (5분)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "increase(kraft_api_fallback_used_total[5m])",
          "legendFormat": "fallback used ({{from}}→{{to}})"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "increase(kraft_api_fallback_exhausted_total[5m])",
          "legendFormat": "fallback exhausted"
        }
      ]
    },
    {
      "id": 10,
      "title": "호스트 디스크 사용률 (/)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "1 - (node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\"})",
          "legendFormat": "used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.90 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "호스트 메모리 사용률",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})",
          "legendFormat": "used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.90 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "호스트 CPU 사용률",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 4 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "1 - avg(rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m]))",
          "legendFormat": "cpu used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    }
  ]
}
