# Local `npm run dev` overrides (frontend only, no Docker Compose).
# Next.js loads this automatically. .env.local is gitignored — never commit it.
#
# HOW TO USE:
#   cp .env.local.example .env.local
#   Fill in the values below.
#
# 백엔드를 IntelliJ/bootRun으로 로컬 실행 중이라면(../.env.local.example 참고),
# 백엔드는 localhost:8080에 뜨지만 web/.env.example의 기본값(http://backend:8080)은
# Docker 네트워크 안에서만 resolve되는 호스트명이라 여기서는 fetch failed가 난다.
# 아래처럼 로컬 주소로 덮어써야 한다.

# ── Backend ────────────────────────────────────────────────────────────────
KRAFT_BACKEND_INTERNAL_URL=http://localhost:8080
KRAFT_PUBLIC_BASE_URL=http://localhost:3000

# ── ISR on-demand revalidate webhook 검증용 (백엔드 .env.local의 값과 동일해야 함) ──
KRAFT_REVALIDATE_SECRET=

# ── 검색엔진 소유권 확인 (선택, 비워두면 미노출) ────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# ── 카카오 애드핏 광고 단위 (선택, 비워두면 해당 위치 광고 미노출) ──────────
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_ROUNDS_LIST=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_ROUNDS_DETAIL=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_FREQUENCY=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_ROUNDS_LIST_DESKTOP=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_ROUNDS_DETAIL_DESKTOP=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_FREQUENCY_DESKTOP=
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_STICKY=

# ── 구글 애드센스 (계정 승인 전, 비워두면 플레이스홀더만 표시) ───────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_UNIT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_UNIT_ROUNDS_LIST=
NEXT_PUBLIC_ADSENSE_UNIT_ROUNDS_DETAIL=
NEXT_PUBLIC_ADSENSE_UNIT_FREQUENCY=
NEXT_PUBLIC_ADSENSE_UNIT_ROUNDS_LIST_MOBILE=
NEXT_PUBLIC_ADSENSE_UNIT_ROUNDS_DETAIL_MOBILE=
NEXT_PUBLIC_ADSENSE_UNIT_FREQUENCY_MOBILE=
