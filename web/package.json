{
  "name": "kraft-lotto-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint src",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:content": "playwright test --config=playwright.content.config.ts",
    "test:e2e:ad-overlay": "playwright test --config=playwright.ad-overlay.config.ts",
    "e2e:serve": "node scripts/start-standalone.mjs"
  },
  "dependencies": {
    "next": "16.2.11",
    "pino": "^10.3.1",
    "pino-rotating-file-stream": "^0.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.11",
    "jsdom": "^29.1.1",
    "subset-font": "^2.5.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "undici": "^7.28.0",
    "sharp": "^0.35.3"
  }
}
