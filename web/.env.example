# Backend internal URL (used for server-side API calls inside Docker network)
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080

# Public base URL for canonical URLs, OG tags, sitemap, and robots.txt
KRAFT_PUBLIC_BASE_URL=https://your-domain.com

# Shared secret for on-demand ISR revalidation (POST /api/revalidate)
# Must match the backend spring.kraft.revalidate.secret value
KRAFT_REVALIDATE_SECRET=change-me

# Search engine site ownership verification (HTML tag method)
# Google Search Console: https://search.google.com/search-console -> 소유권 확인 -> HTML 태그 -> content="..." 값만 입력
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# 네이버 서치어드바이저: https://searchadvisor.naver.com -> 사이트 소유 확인 -> HTML 태그 -> content="..." 값만 입력
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# Kakao Adfit 광고 단위 코드 (카카오 애드핏 콘솔에서 발급: https://adfit.kakao.com)
# 비어 있으면 해당 위치의 광고가 표시되지 않습니다.
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_FREQUENCY=
# 데스크톱(1024px+) 전용 광고 단위 코드 (권장 크기: 728×90)
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_FREQUENCY_DESKTOP=
# 모바일 하단 고정 배너 (전 페이지 공용, 권장 크기: 320×50)
NEXT_PUBLIC_KAKAO_ADFIT_UNIT_STICKY=

# Google 애드센스 (계정 승인 전까지는 slot 미설정 시 기본적으로 아무것도 렌더하지 않습니다.
# 로컬에서 레이아웃/CLS만 미리 검증하려면 아래를 true로 설정해 플레이스홀더를 켤 수 있습니다)
NEXT_PUBLIC_ADSENSE_RESERVE_PLACEHOLDER=
# 게시자 ID (애드센스 대시보드 -> 계정 -> 계정 정보, ca-pub-로 시작)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# 광고 단위별 슬롯 ID (애드센스 대시보드에서 위치별로 생성)
NEXT_PUBLIC_ADSENSE_UNIT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_UNIT_FREQUENCY=
# 모바일(1024px 미만) 인피드 전용 슬롯 ID (권장 크기: 300×250)
NEXT_PUBLIC_ADSENSE_UNIT_FREQUENCY_MOBILE=
