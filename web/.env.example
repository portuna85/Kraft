# Backend internal URL (used for server-side API calls inside Docker network)
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080

# Public base URL for canonical URLs, OG tags, sitemap, and robots.txt
KRAFT_PUBLIC_BASE_URL=https://your-domain.com

# Shared secret for on-demand ISR revalidation (POST /api/revalidate)
# Must match the backend spring.kraft.revalidate.secret value
KRAFT_REVALIDATE_SECRET=change-me
