# ============================================================
# Kraft Lotto production environment example
# Copy to .env and fill in production secrets:
#   cp .env.prod.example .env
# ============================================================

SPRING_PROFILES_ACTIVE=prod

# Production MariaDB
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_HOST=mariadb
KRAFT_DB_PORT=3306
KRAFT_DB_USER=your-prod-db-user
KRAFT_DB_PASSWORD=your-prod-db-password
KRAFT_DB_ROOT_PASSWORD=your-prod-root-password
KRAFT_DB_CONNECTIVITY_CHECK_ENABLED=true
KRAFT_DB_CONNECTIVITY_CHECK_TIMEOUT_MS=1500

KRAFT_IN_CONTAINER=true
KRAFT_DOTENV_ENABLED=true

# Production app behavior
KRAFT_API_CLIENT=smok
KRAFT_API_URL=https://www.dhlottery.co.kr/common.do
KRAFT_PUBLIC_BASE_URL=https://www.kraft.io.kr
# Recommended in addition to KRAFT_SECURITY_OPS_ALLOWED_IPS.
KRAFT_SECURITY_OPS_REQUIRED_TOKEN=change-me-ops-token
KRAFT_HISTORY_INIT_ENABLED=false

# Keep these aligned with the deployment manifest.
KRAFT_COLLECT_AUTO_ENABLED=true
KRAFT_COLLECT_AUTO_ZONE=Asia/Seoul
KRAFT_COLLECT_AUTO_CRON_SATURDAY_22_30=0 30 22 ? * SAT
KRAFT_COLLECT_AUTO_CRON_SUNDAY_07_00=0 0 7 ? * SUN

