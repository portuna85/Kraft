# Production environment template — rendered by scripts/deploy/render-env.sh via envsubst.
# All ${VAR} tokens are substituted from GitHub Actions secrets at deploy time.
# NOT read by Spring Boot directly. Spring Boot containers receive these
# values as OS environment variables via 'environment:' blocks in docker-compose.prod.yml.

# ── MariaDB container ─────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=${MARIADB_ROOT_PASSWORD}
MARIADB_DATABASE=kraft_lotto
MARIADB_USER=kraft_lotto
MARIADB_PASSWORD=${MARIADB_PASSWORD}

# ── Backend (Spring Boot) ─────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
KRAFT_DB_USERNAME=kraft_lotto
KRAFT_DB_PASSWORD=${KRAFT_DB_PASSWORD}
KRAFT_LOG_PATH=/app/logs
KRAFT_OPS_TOKEN=${KRAFT_OPS_TOKEN}
KRAFT_REVALIDATE_SECRET=${KRAFT_REVALIDATE_SECRET}
KRAFT_SAVED_MAX_PER_CLIENT=100
KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE=${KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE}
KRAFT_EXTERNAL_LOTTO_AUTO_COLLECT_CRON=0 0 22 * * SAT
KRAFT_SECURITY_TRUSTED_PROXY_CIDR=${KRAFT_SECURITY_TRUSTED_PROXY_CIDR}
KRAFT_SECURITY_RATE_LIMIT_PER_MINUTE=120
KRAFT_SECURITY_RATE_LIMIT_MAX_KEYS=10000
# admin_users 테이블이 비어있을 때만 1회성으로 계정을 생성함 (AdminBootstrap.java).
# 계정 생성 후에는 이 두 시크릿 값을 제거할 것.
KRAFT_ADMIN_BOOTSTRAP_USERNAME=${KRAFT_ADMIN_BOOTSTRAP_USERNAME}
KRAFT_ADMIN_BOOTSTRAP_PASSWORD=${KRAFT_ADMIN_BOOTSTRAP_PASSWORD}

# ── Revalidate ────────────────────────────────────────────────────────────────
KRAFT_REVALIDATE_WEB_URL=http://web:3000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080
KRAFT_PUBLIC_BASE_URL=${KRAFT_PUBLIC_BASE_URL}

# ── Caddy ─────────────────────────────────────────────────────────────────────
KRAFT_DOMAIN=${KRAFT_DOMAIN}
KRAFT_ADMIN_DOMAIN=${KRAFT_ADMIN_DOMAIN}

# ── Docker image refs ─────────────────────────────────────────────────────────
KRAFT_BACKEND_IMAGE_REF=${KRAFT_BACKEND_IMAGE_REF}
KRAFT_BACKEND_IMAGE_TAG=${KRAFT_BACKEND_IMAGE_TAG}
KRAFT_WEB_IMAGE_REF=${KRAFT_WEB_IMAGE_REF}
KRAFT_WEB_IMAGE_TAG=${KRAFT_WEB_IMAGE_TAG}

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
ALERTMANAGER_DISCORD_WEBHOOK_URL=${ALERTMANAGER_DISCORD_WEBHOOK_URL}
