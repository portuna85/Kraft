# Production environment template — copy to .env on the production server.
# NOT read by Spring Boot directly. Spring Boot in containers receives these
# values as OS environment variables via the 'environment:' blocks in
# docker-compose.prod.yml.

# ── MariaDB container ─────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=kraft_lotto
MARIADB_USER=kraft_lotto
MARIADB_PASSWORD=

# ── Backend (Spring Boot) ─────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
KRAFT_DB_URL=jdbc:mariadb://mariadb:3306/kraft_lotto?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
KRAFT_DB_USERNAME=kraft_lotto
KRAFT_DB_PASSWORD=
KRAFT_LOG_PATH=/app/logs
KRAFT_OPS_TOKEN=
KRAFT_REVALIDATE_SECRET=
KRAFT_SAVED_MAX_PER_CLIENT=100
KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE=
KRAFT_EXTERNAL_LOTTO_AUTO_COLLECT_CRON=0 35 22 * * SAT
KRAFT_SECURITY_TRUSTED_PROXY_CIDR=172.28.0.0/16
KRAFT_SECURITY_RATE_LIMIT_PER_MINUTE=120
KRAFT_SECURITY_RATE_LIMIT_MAX_KEYS=10000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080
KRAFT_PUBLIC_BASE_URL=https://kraft.example.com

# ── Caddy ─────────────────────────────────────────────────────────────────────
KRAFT_DOMAIN=kraft.example.com
KRAFT_ADMIN_DOMAIN=admin.kraft.example.com

# ── Docker image refs ─────────────────────────────────────────────────────────
KRAFT_BACKEND_IMAGE_REF=ghcr.io/portuna85/kraft-backend
KRAFT_BACKEND_IMAGE_TAG=latest
KRAFT_WEB_IMAGE_REF=ghcr.io/portuna85/kraft-web
KRAFT_WEB_IMAGE_TAG=latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_SLACK_CHANNEL=#alerts
