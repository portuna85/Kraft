{
  "id": null,
  "uid": "kraft-overview",
  "title": "KRAFT 운영 개요",
  "tags": ["kraft"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Backend up",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"kraft-backend\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "5xx 오류율",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"kraft-backend\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"kraft-backend\"}[5m]))",
          "refId": "A",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 3,
      "title": "P95 응답 시간",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"kraft-backend\"}[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "JVM heap 사용률",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"kraft-backend\"} / jvm_memory_max_bytes{area=\"heap\",job=\"kraft-backend\"}",
          "refId": "A",
          "legendFormat": "heap usage"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 5,
      "title": "데이터 신선도 (지연 일수)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "kraft_lotto_data_stale_days{job=\"kraft-backend\"}",
          "refId": "A",
          "legendFormat": "stale days"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "d" } }
    },
    {
      "id": 6,
      "title": "추천 실패율",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(kraft_lotto_recommend_failures_total{job=\"kraft-backend\"}[10m])) / sum(rate(kraft_lotto_recommend_requests_total{job=\"kraft-backend\"}[10m]))",
          "refId": "A",
          "legendFormat": "실패율"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 7,
      "title": "마지막 백업 이후 경과 시간",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "time() - kraft_backup_last_success_timestamp_seconds", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
