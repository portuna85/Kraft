www.{$KRAFT_DOMAIN} {
	redir https://{$KRAFT_DOMAIN}{uri} permanent
}

{$KRAFT_DOMAIN} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header Permissions-Policy "geolocation=(), microphone=(), camera=()"
	encode zstd gzip

	# route { } 로 감싸서 Caddy의 자동 specificity 정렬을 비활성화하고
	# 아래 순서(첫 매치 우선)를 그대로 보장한다. 정렬에 맡기면 @blocked가
	# catch-all reverse_proxy 뒤로 밀려나 /admin* 차단이 무력화된다.
	route {
		@blocked path /actuator* /ops* /admin* /api/revalidate
		respond @blocked 403

		# 정적 자산 장기 캐시 (Next.js 콘텐츠 해시 포함)
		@immutable path /_next/static/* /icon/* /apple-icon /opengraph-image
		handle @immutable {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle /api/v1/* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle {
			# 모든 페이지 경로: 브라우저 SWR 60s+300s.
			# nonce 기반 CSP 때문에 HTML+CSP 헤더가 함께 캐시돼야 안전하므로
			# CDN용 s-maxage는 추가하지 않음 (CDN 도입 시 nonce 제거 먼저 필요).
			header Cache-Control "public, max-age=60, stale-while-revalidate=300"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}
	}
}

{$KRAFT_ADMIN_DOMAIN} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header Permissions-Policy "geolocation=(), microphone=(), camera=()"
	encode zstd gzip

	# 진단용 액세스 로그. remote_ip allowlist가 실제로 어떤 IP를 보는지 확인하기 위함
	# (2026-06-23 인시던트: 자가 헬스체크/스모크 테스트가 막혀 원인 파악이 필요했음).
	log {
		output stdout
		format console
	}

	route {
		# 관리자 도메인 IP 제한. 기본값은 docker-compose.prod.yml의 KRAFT_ADMIN_ALLOWED_CIDR
		# 환경변수 단계에서 보장한다(여기 :default는 compose 없이 caddy를 직접 띄울 때를
		# 위한 2차 방어선일 뿐, 정상 운영에서는 항상 compose가 채운 값이 들어온다).
		@not_allowed not remote_ip {$KRAFT_ADMIN_ALLOWED_CIDR:0.0.0.0/0 ::/0}
		respond @not_allowed 403

		@blocked path /actuator*
		respond @blocked 403

		# 정적 자산 장기 캐시
		@immutable path /_next/static/* /icon/* /apple-icon /opengraph-image
		handle @immutable {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle /api/v1/* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle_path /ops-api/* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		# 관리자 화면(Thymeleaf SSR) — 최초 인프라 설정 때부터 이 라우트가
		# 빠져 있어 /admin*이 전부 web(Next.js)의 catch-all로 빠져 404였다.
		handle /admin* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle /grafana/* {
			reverse_proxy grafana:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle {
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}
	}
}
