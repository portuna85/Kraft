# Prometheus 전용 metrics 리스너. admin API(기본 127.0.0.1:2019, 인증 없이 전체 설정을
# 읽고 바꿀 수 있음)는 loopback에만 묶어두고, 이 리스너는 metrics만 서빙해 app/monitoring
# 네트워크의 다른 컨테이너에도 안전하게 노출한다. 호스트에는 포트를 publish하지 않는다.
:2020 {
	metrics
}

www.{$KRAFT_DOMAIN} {
	redir https://{$KRAFT_DOMAIN}{uri} permanent
}

{$KRAFT_DOMAIN} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header Permissions-Policy "geolocation=(), microphone=(), camera=()"
	# 앱(web/backend)이 응답마다 자체 CSP를 설정하지만, Caddy가 직접 만드는 403(@blocked) 등에는
	# 앱 헤더가 안 붙는다 — 그런 응답도 프레이밍 공격에서 방어되도록 최소 헤더를 여기서도 건다.
	header X-Frame-Options "DENY"
	encode zstd gzip

	# route { } 로 감싸서 Caddy의 자동 specificity 정렬을 비활성화하고
	# 아래 순서(첫 매치 우선)를 그대로 보장한다. 정렬에 맡기면 @blocked가
	# catch-all reverse_proxy 뒤로 밀려나 /admin* 차단이 무력화된다.
	route {
		@blocked path /actuator* /ops* /admin* /api/revalidate
		respond @blocked 403

		# 정적 자산 장기 캐시 (Next.js 콘텐츠 해시 포함)
		# 주의: /rounds/opengraph-image 같은 라우트 전용 OG는 이 경로 매치(정확히 /opengraph-image)에
		# 걸리지 않고 아래 catch-all 60s 캐시로 떨어진다. 콘텐츠 해시가 없는 경로라 의도적으로 그대로 둔다.
		@immutable path /_next/static/* /icon/* /apple-icon /opengraph-image
		handle @immutable {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		# OG 이미지: 쿼리 파라미터(번호·회차·당첨금 등)에 데이터가 자기완결적으로 들어 있어
		# 사실상 불변이다. 소셜 스크레이퍼·재공유 트래픽의 이미지 재렌더 비용을 없애기 위해 장기 캐시.
		@og path /api/og/*
		handle @og {
			header Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle /api/v1/* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle {
			# 모든 페이지 경로: 브라우저 SWR 60s+300s.
			# nonce 기반 CSP 때문에 HTML+CSP 헤더가 함께 캐시돼야 안전하므로
			# CDN용 s-maxage는 추가하지 않음 (CDN 도입 시 nonce 제거 먼저 필요).
			header Cache-Control "public, max-age=60, stale-while-revalidate=300"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
				@error status 4xx 5xx
				handle_response @error {
					# copy_response가 없으면 원본 상태코드/본문이 버려지고 200 빈 응답으로 대체된다 —
					# 이 블록의 목적은 헤더 교체뿐이므로 반드시 원본 응답을 그대로 복사한 뒤 헤더만 덮어쓴다.
					copy_response
					# 4xx/5xx 오류 응답은 위의 기본 Cache-Control을 상속해 캐시되면 안 되므로 명시적으로 덮어쓴다.
					header Cache-Control "no-store"
				}
			}
		}
	}
}

{$KRAFT_ADMIN_DOMAIN} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header Permissions-Policy "geolocation=(), microphone=(), camera=()"
	header X-Frame-Options "DENY"
	encode zstd gzip

	# 진단용 액세스 로그. remote_ip allowlist가 실제로 어떤 IP를 보는지 확인하기 위함
	# (2026-06-23 인시던트: 자가 헬스체크/스모크 테스트가 막혀 원인 파악이 필요했음).
	log {
		output stdout
		format console
	}

	route {
		# 관리자 도메인 IP 제한. 기본값은 docker-compose.prod.yml의 KRAFT_ADMIN_ALLOWED_CIDR
		# 환경변수 단계에서 보장한다(여기 :default는 compose 없이 caddy를 직접 띄울 때를
		# 위한 2차 방어선일 뿐, 정상 운영에서는 항상 compose가 채운 값이 들어온다).
		@not_allowed not remote_ip {$KRAFT_ADMIN_ALLOWED_CIDR:0.0.0.0/0 ::/0}
		respond @not_allowed 403

		@blocked path /actuator*
		respond @blocked 403

		# 정적 자산 장기 캐시
		@immutable path /_next/static/* /icon/* /apple-icon /opengraph-image
		handle @immutable {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle /api/v1/* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle_path /ops-api/* {
			rewrite * /ops{uri}
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		# 관리자 화면(Thymeleaf SSR) — 최초 인프라 설정 때부터 이 라우트가
		# 빠져 있어 /admin*이 전부 web(Next.js)의 catch-all로 빠져 404였다.
		handle /admin* {
			reverse_proxy backend:8080 {
				header_up X-Real-IP {remote_host}
				transport http {
					dial_timeout 3s
					response_header_timeout 5s
				}
			}
		}

		handle /grafana/* {
			reverse_proxy grafana:3000 {
				header_up X-Real-IP {remote_host}
			}
		}

		handle {
			reverse_proxy web:3000 {
				header_up X-Real-IP {remote_host}
			}
		}
	}
}
