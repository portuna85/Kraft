# Local Spring Boot direct-run overrides (IntelliJ / bootRun).
# Loaded via spring.config.import in application-local.yml.
# NOT read by Docker Compose — see .env for that.
#
# HOW TO USE:
#   cp .env.local.example .env.local
#   Fill in the values below. .env.local is gitignored — never commit it.
#
# DEFAULT: H2 in-memory DB — no Docker required. Just run the app in IntelliJ.
# The H2 web console is available at http://localhost:8080/h2-console (JDBC URL 그대로 입력).

# ── Database (H2 in-memory — default, Docker 불필요) ─────────────────────────
# 아래 값이 기본값이므로 H2를 쓸 때는 이 섹션을 그대로 두거나 비워도 됩니다.
# KRAFT_DB_URL=jdbc:h2:mem:kraft-lotto;MODE=MySQL;DB_CLOSE_DELAY=-1;DATABASE_TO_LOWER=TRUE
# KRAFT_DB_USERNAME=sa
# KRAFT_DB_PASSWORD=
# KRAFT_FLYWAY_ENABLED=false
# KRAFT_JPA_DDL_AUTO=create-drop

# ── 관리자 계정 초기화 (H2는 매 시작마다 초기화되므로 항상 필요) ─────────────
KRAFT_ADMIN_BOOTSTRAP_USERNAME=admin
KRAFT_ADMIN_BOOTSTRAP_PASSWORD=admin

# ── MariaDB(Docker)로 전환하는 경우 아래 주석을 해제 ─────────────────────────
# PREREQUISITE: docker compose up -d mariadb
#
# KRAFT_DB_URL=jdbc:mariadb://localhost:3306/kraft_lotto?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
# KRAFT_DB_USERNAME=kraft_lotto
# KRAFT_DB_PASSWORD=   # .env 의 MARIADB_PASSWORD 값을 복사
# KRAFT_FLYWAY_ENABLED=true
# KRAFT_FLYWAY_BASELINE_ON_MIGRATE=true
# KRAFT_FLYWAY_BASELINE_VERSION=7
# KRAFT_JPA_DDL_AUTO=validate

# ── Application ───────────────────────────────────────────────────────────────
KRAFT_OPS_TOKEN=local-dev-ops-token
KRAFT_REVALIDATE_SECRET=
KRAFT_SAVED_MAX_PER_CLIENT=100
KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE=
KRAFT_EXTERNAL_LOTTO_AUTO_COLLECT_CRON=0 30 21 * * SAT
KRAFT_EXTERNAL_LOTTO_REFERER=https://www.dhlottery.co.kr/lt645/result
KRAFT_EXTERNAL_LOTTO_REQUESTED_WITH=XMLHttpRequest
KRAFT_SECURITY_TRUSTED_PROXY_CIDR=127.0.0.1/32
KRAFT_SECURITY_RATE_LIMIT_PER_MINUTE=120
KRAFT_SECURITY_RATE_LIMIT_MAX_KEYS=10000
KRAFT_PUBLIC_BASE_URL=http://localhost:8080
KRAFT_LOG_PATH=build/logs
