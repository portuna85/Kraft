# Local development environment template
# Copy to .env.local (gitignored) to override application-local.yml defaults.
# This file is NOT loaded by Docker Compose — it is only read by Spring Boot
# via spring.config.import in application-local.yml (local profile only).
#
# .env (in project root) is Docker Compose's env file — do NOT use it for
# direct local Spring Boot runs, because it contains Docker-internal hostnames
# (e.g. mariadb) that are unresolvable outside the Docker network.

KRAFT_DB_URL=jdbc:mariadb://localhost:3306/kraft_lotto?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
KRAFT_DB_USERNAME=kraft_lotto
KRAFT_DB_PASSWORD=
KRAFT_DOMAIN=localhost
KRAFT_ADMIN_DOMAIN=admin.localhost
KRAFT_PUBLIC_BASE_URL=http://localhost
KRAFT_LOG_PATH=logs
KRAFT_BACKEND_IMAGE_REF=demo-backend
KRAFT_BACKEND_IMAGE_TAG=latest
KRAFT_WEB_IMAGE_REF=demo-web
KRAFT_WEB_IMAGE_TAG=latest
KRAFT_BACKEND_INTERNAL_URL=http://backend:8080
KRAFT_SAVED_MAX_PER_CLIENT=100
KRAFT_OPS_TOKEN=change-me
KRAFT_EXTERNAL_LOTTO_URL_TEMPLATE=
KRAFT_EXTERNAL_LOTTO_AUTO_COLLECT_CRON=0 35 22 * * SAT
KRAFT_REVALIDATE_SECRET=change-me
