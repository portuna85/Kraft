# ============================================================
# Kraft Lotto local environment example
# Copy to .env and fill in your local secrets:
#   cp .env.local.example .env
# ============================================================

SPRING_PROFILES_ACTIVE=local

# Local MariaDB
KRAFT_DB_NAME=kraft_lotto
KRAFT_DB_URL=jdbc:mariadb://localhost:3306/kraft_lotto?rewriteBatchedStatements=true&useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Seoul&connectTimeout=3000
KRAFT_DB_HOST=localhost
KRAFT_DB_PORT=3306
KRAFT_DB_USER=your-local-db-user
KRAFT_DB_PASSWORD=your-local-db-password
KRAFT_DB_CONNECTIVITY_CHECK_ENABLED=true
KRAFT_DB_CONNECTIVITY_CHECK_TIMEOUT_MS=1500

# Optional, keeps the local runtime aligned with the host environment.
KRAFT_DB_LOCAL_HOST=localhost
KRAFT_IN_CONTAINER=false
KRAFT_DOTENV_ENABLED=true

# Local app behavior
KRAFT_API_CLIENT=mock
KRAFT_API_URL=http://localhost
KRAFT_API_MOCK_LATEST_ROUND=0
KRAFT_HISTORY_INIT_ENABLED=false
KRAFT_COLLECT_AUTO_ENABLED=false
KRAFT_SECURITY_OPS_REQUIRED_TOKEN=change-me-ops-token

