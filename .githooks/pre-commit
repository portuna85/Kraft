#!/usr/bin/env sh
set -eu

if command -v py >/dev/null 2>&1; then
  py -3 scripts/check_utf8.py --staged
elif command -v python3 >/dev/null 2>&1; then
  python3 scripts/check_utf8.py --staged
elif command -v python >/dev/null 2>&1; then
  python scripts/check_utf8.py --staged
else
  echo "ERROR: python3 or python is required to run UTF-8 pre-commit checks." >&2
  exit 1
fi
