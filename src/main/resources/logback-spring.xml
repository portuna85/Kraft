<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="./logs"/>

    <!--
        requestId:-  → MDC 값 없을 때 빈 문자열 (리터럴 "null" 출력 방지)
        %-5level     → 레벨 5자 고정폭 좌측 정렬
        %logger{40}  → 패키지 최대 40자 축약
    -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{requestId:-}] %logger{40} - %msg%n"/>
    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%15.15thread] [%X{requestId:-}] %logger{36} - %msg%n"/>

    <!-- ══ 공통 Appenders ═══════════════════════════════════════════════════════ -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- kraft.log — INFO+ 통합 (운영 모니터링 메인) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/kraft.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/kraft.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- kraft-collect.log — 수집 레이어 전용 (additivity=true 로 kraft.log 에도 전파) -->
    <appender name="COLLECT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/kraft-collect.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/kraft-collect.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!--
        kraft-api.log — 외부 API 클라이언트 전용
        ThresholdFilter 미설정 → 로거 레벨이 기록 범위를 결정
        local: DEBUG 이상 / prod: INFO 이상(→ 실질적으로 WARN 이상)
    -->
    <appender name="API_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/kraft-api.log</file>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/kraft-api.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- kraft-error.log — ERROR+ 전용 (장애 초동 대응, 60일 보존) -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/kraft-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/kraft-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ══ 공통 비동기 래퍼 ══════════════════════════════════════════════════════
         파일 I/O를 별도 스레드에 위임 → 요청 스레드 지연 최소화
         discardingThreshold=0: 큐 포화 시에도 로그 이벤트 유실 방지
    ══════════════════════════════════════════════════════════════════════════ -->

    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE"/>
    </appender>

    <appender name="ASYNC_COLLECT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="COLLECT_FILE"/>
    </appender>

    <appender name="ASYNC_API" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="API_FILE"/>
    </appender>

    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>128</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <!-- ══ 프레임워크 노이즈 억제 ════════════════════════════════════════════════ -->

    <logger name="org.hibernate.orm"   level="WARN"/>
    <logger name="com.zaxxer.hikari"   level="WARN"/>

    <!-- ══ 수집 레이어 로거 ══════════════════════════════════════════════════════
         additivity=true: kraft-collect.log + root 경유로 kraft.log에도 전파
    ══════════════════════════════════════════════════════════════════════════ -->

    <logger name="com.kraft.lotto.feature.winningnumber" additivity="true">
        <appender-ref ref="ASYNC_COLLECT"/>
    </logger>

    <!-- ══ 외부 API 클라이언트 로거 ═════════════════════════════════════════════
         additivity=true: kraft-api.log + kraft-collect.log + kraft.log 동시 기록
    ══════════════════════════════════════════════════════════════════════════ -->

    <logger name="com.kraft.lotto.feature.winningnumber.application.DhLotteryApiClient" additivity="true">
        <appender-ref ref="ASYNC_API"/>
    </logger>
    <logger name="com.kraft.lotto.feature.winningnumber.application.SmokLottoApiClient" additivity="true">
        <appender-ref ref="ASYNC_API"/>
    </logger>

    <!-- ══ 로컬 프로파일 ═════════════════════════════════════════════════════════
         kraft-warn.log : WARN 단독 → 경고 패턴 파악용 (7일 보존)
         kraft-debug.log: DEBUG 단독 → 디버깅 상세 추적용 (3일 보존)
         두 파일 모두 LevelFilter(ACCEPT/DENY)로 해당 레벨만 정확히 기록
    ══════════════════════════════════════════════════════════════════════════ -->

    <springProfile name="local">

        <appender name="WARN_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/kraft-warn.log</file>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>WARN</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/archived/kraft-warn.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>100MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <appender name="DEBUG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/kraft-debug.log</file>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>DEBUG</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/archived/kraft-debug.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>20MB</maxFileSize>
                <maxHistory>3</maxHistory>
                <totalSizeCap>100MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <appender name="ASYNC_WARN" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>128</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="WARN_FILE"/>
        </appender>

        <appender name="ASYNC_DEBUG" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="DEBUG_FILE"/>
        </appender>

        <logger name="com.kraft" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR"/>
            <appender-ref ref="ASYNC_WARN"/>
            <appender-ref ref="ASYNC_DEBUG"/>
        </root>

    </springProfile>

    <!-- ══ 운영 프로파일 ═════════════════════════════════════════════════════════
         INFO 이상만 기록, API 클라이언트는 WARN 이상만 kraft-api.log에 기록
    ══════════════════════════════════════════════════════════════════════════ -->

    <springProfile name="prod">

        <logger name="com.kraft" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

    </springProfile>

</configuration>
